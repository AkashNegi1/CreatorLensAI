# ─── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ──────────────────────────
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://creatorlens:creatorlens_password@localhost:5433/creatorlens_db

# ─── Redis ──────────────────────────────────────────
# Redis is available for future job queue. Not required for current chat flow.
REDIS_HOST=localhost
REDIS_PORT=6380

# ─── Qdrant Vector DB ───────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=creatorlens_chunks

# ─── Groq LLM ───────────────────────────────────────
# Required for RAG chat answers. Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─── YouTube Data API v3 ────────────────────────────
# Required for YouTube transcript + metadata ingestion.
# Get a key at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Instagram (optional) ───────────────────────────
# Browser name for yt-dlp cookies (chrome, firefox, edge, etc.).
# If unset, Instagram public Reel scraping may fail for some URLs.
# INSTAGRAM_COOKIES_BROWSER=chrome
